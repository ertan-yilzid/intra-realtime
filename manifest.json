{
  "manifest_version": 3,
  "name": "INTRA Log Update",
  "version": "1.0",
  "description": "Real-time logtime from Alcasar",
  "permissions": ["storage"],
  "host_permissions": [
    "https://api.laplateforme.io/*",
    "https://alcasar.laplateforme.io/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://intra.laplateforme.io/*"],
      "js": ["inject.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://intra.laplateforme.io/*"],
      "js": ["content.js"],
      "run_at": "document_start",
      "world": "ISOLATED"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
